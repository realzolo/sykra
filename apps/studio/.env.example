# PostgreSQL connection string (required)
# Example: postgres://user:password@localhost:5432/spec_axis
DATABASE_URL=

# Scheduler service (required)
SCHEDULER_BASE_URL=http://localhost:8200
SCHEDULER_TOKEN=
TASK_SCHEDULER_TOKEN=

# Encryption key for sensitive data (required, 64 hex chars)
ENCRYPTION_KEY=

# Auth policy
EMAIL_VERIFICATION_REQUIRED=false

# Email delivery bootstrap
EMAIL_PROVIDER=console
EMAIL_FROM=
RESEND_API_KEY=
STUDIO_BASE_URL=http://localhost:8109

# Redis (required)
REDIS_URL=redis://:password@localhost:6379/0
