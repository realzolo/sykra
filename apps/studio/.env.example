# PostgreSQL connection string (required)
# Example: postgres://user:password@localhost:5432/spec_axis
DATABASE_URL=

# ============================================================
# Scheduler service (Go)
# ============================================================
# Base URL for the scheduler service
SCHEDULER_BASE_URL=http://localhost:8200
# Shared token for scheduler auth (optional but recommended)
SCHEDULER_TOKEN=your_scheduler_token

# Optional token for internal task endpoints (e.g. /api/codebase/sync)
TASK_SCHEDULER_TOKEN=

# ============================================================
# Encryption key for sensitive data (32 bytes = 64 hex characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or: openssl rand -hex 32
# IMPORTANT: Keep this secret and back it up securely!
# ============================================================
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# ============================================================
# Auth
# ============================================================
# Require email verification before login (true|false). Default: true
EMAIL_VERIFICATION_REQUIRED=false

# ============================================================
# Email (Notifications)
# ============================================================
# Email provider: console|resend
EMAIL_PROVIDER=console
# From address (required for resend)
EMAIL_FROM="Spec-Axis <no-reply@example.com>"
# Resend API key (required when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
# Public base URL for links included in emails (optional but recommended)
STUDIO_BASE_URL=http://localhost:8109

# ============================================================
# Codebase cache (local mirror + workspaces)
# ============================================================
# Root directory for all mirrors/workspaces. Default: <project>/.cache/codebase
CODEBASE_ROOT=
# Override mirror directory (bare git mirrors). Default: <CODEBASE_ROOT>/mirrors
CODEBASE_MIRRORS_DIR=
# Override workspace directory (per-job worktrees). Default: <CODEBASE_ROOT>/workspaces
CODEBASE_WORKSPACES_DIR=
# Mirror refresh interval in ms for on-demand sync. Default: 60000
CODEBASE_SYNC_INTERVAL_MS=60000
# Max wait time to acquire mirror lock (ms). Default: 120000
CODEBASE_LOCK_TIMEOUT_MS=120000
# Stale lock threshold (ms). Default: 300000
CODEBASE_LOCK_STALE_MS=300000
# Workspace auto-clean TTL (ms). Default: 21600000 (6 hours)
CODEBASE_WORKSPACE_TTL_MS=21600000
# Max file size (bytes) to preview in UI. Default: 262144 (256 KB)
CODEBASE_FILE_MAX_BYTES=262144
# Git command timeout (ms). Default: 120000
CODEBASE_GIT_TIMEOUT_MS=120000
# Git executable path (use full path if git is not on PATH)
CODEBASE_GIT_BIN=git

# BullMQ / Redis
# Redis connection string used by BullMQ workers (rediss:// for TLS)
REDIS_URL=redis://:password@localhost:6379/0
# Max concurrent jobs per BullMQ worker process. Default: 2 in code.
BULLMQ_CONCURRENCY=

# Analyze admission control (rate limit + dedupe + queue backpressure)
# Time window for analyze API rate limit (ms)
ANALYZE_RATE_LIMIT_WINDOW_MS=60000
# Max analyze requests per window for the same org+user+project
ANALYZE_RATE_LIMIT_USER_PROJECT_MAX=6
# Max analyze requests per window for the same org
ANALYZE_RATE_LIMIT_ORG_MAX=60
# Auxiliary IP-based cap per window (hashed IP key)
ANALYZE_RATE_LIMIT_IP_MAX=120
# Dedupe result TTL (seconds): identical requests reuse existing report/task during this period
ANALYZE_DEDUPE_TTL_SEC=180
# In-flight dedupe lock TTL (seconds)
ANALYZE_DEDUPE_LOCK_TTL_SEC=15
# Backpressure thresholds: active reports in pending/analyzing status
ANALYZE_BACKPRESSURE_PROJECT_ACTIVE_MAX=6
ANALYZE_BACKPRESSURE_ORG_ACTIVE_MAX=60
# Retry hint when backpressure rejects request (seconds)
ANALYZE_BACKPRESSURE_RETRY_AFTER_SEC=15

# Report lifecycle timeout guard (ms)
# Pending/analyzing reports older than this threshold are auto-marked as failed.
ANALYZE_REPORT_TIMEOUT_MS=1200000
# Min interval between global timeout sweeps in API workers (ms)
ANALYZE_REPORT_TIMEOUT_SWEEP_INTERVAL_MS=30000
