# Supabase project URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Supabase anon key (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key
# Supabase service role key (server-side only, keep secret)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# GitHub Personal Access Token for org-level access
GITHUB_PAT=your_github_pat

# Optional custom Anthropic-compatible endpoint (proxy)
ANTHROPIC_BASE_URL=https://your-anthropic-endpoint
# Anthropic API key for Claude analysis
ANTHROPIC_API_KEY=your_anthropic_api_key
