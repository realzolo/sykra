.DS_Store
*.pem

# local caches
**/.codebase/
/.pnpm-store/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env

# config files
/config.toml
/apps/runner/config.toml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# idea
.idea
.claude/settings.local.json
